# Franchise CRM Environment Variables
# Copy this file to .env and fill in your values

# Google Vision OCR
VITE_GOOGLE_VISION_API_KEY=your_google_vision_api_key
VITE_OCR_API_URL=/ocr

# Frappe/ERPNext Configuration
VITE_FRAPPE_URL=https://your-instance.erpnext.com
VITE_FRAPPE_API_KEY=your_api_key
VITE_FRAPPE_API_SECRET=your_api_secret
VITE_TENANT_ID=default

# WhatsApp Integration (Interakt/WATI/Gupshup)
VITE_WHATSAPP_API=https://api.interakt.ai

# Payment Gateway (Razorpay/Cashfree)
VITE_RAZORPAY_KEY=your_razorpay_key_id

# IRP (Invoice Registration Portal)
VITE_IRP_URL=https://einvoice.erpnext.com
VITE_IRP_USER=your_irp_username
VITE_IRP_PASSWORD=your_irp_password

# E-Stamp (SignDesk)
VITE_ESTAMP_URL=https://api.signdesk.in
VITE_ESTAMP_KEY=your_estamp_api_key
